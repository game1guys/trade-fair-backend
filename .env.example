NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# --- MySQL ---
# Docker: user/password below match docker-compose.yml defaults.
# Local (XAMPP/WAMP, etc.): root often has NO password — use MYSQL_USER=root MYSQL_PASSWORD= (empty)
#   then: npm run migrate && npm run db:bootstrap-user  →  switch to tradefair user for the app.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=tradefair
MYSQL_PASSWORD=tradefair_dev
MYSQL_DATABASE=tradefair

JWT_ACCESS_SECRET=change-me-access-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars-long!
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
# Refresh tokens are signed JWTs (HS256); jti is stored server-side for rotation/revocation.

CORS_ORIGIN=http://localhost:3000

# Razorpay (Phase 1 — test keys from Razorpay Dashboard → API Keys)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhooks → create endpoint → copy "Secret" (different from KEY_SECRET). Must match the webhook URL you register.
RAZORPAY_WEBHOOK_SECRET=
