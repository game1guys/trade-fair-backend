NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# --- MySQL ---
# Docker: user/password below match docker-compose.yml defaults.
# Local (XAMPP/WAMP, etc.): root often has NO password — use MYSQL_USER=root MYSQL_PASSWORD= (empty)
#   then: npm run migrate && npm run db:bootstrap-user  →  switch to tradefair user for the app.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=tradefair
MYSQL_PASSWORD=tradefair_dev
MYSQL_DATABASE=tradefair

JWT_ACCESS_SECRET=change-me-access-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars-long!
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
# Refresh tokens are signed JWTs (HS256); jti is stored server-side for rotation/revocation.

CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Transactional email (Gmail: use App Password, not account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# KYC: in development, organizer uploads auto-approve unless you set AUTO_APPROVE_KYC=false.
# In production, leave unset (requires admin KYC) or set AUTO_APPROVE_KYC=true only if you accept that risk.
# AUTO_APPROVE_KYC=false

# Razorpay — Dashboard → Account & Settings → API Keys (Key ID + Key Secret must be from the same mode).
# If checkout returns errors about credentials, you pasted the wrong secret, swapped test/live, or left these empty.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhooks → create endpoint → copy "Secret" (different from KEY_SECRET). Must match the webhook URL you register.
RAZORPAY_WEBHOOK_SECRET=

# Razorpay Route (India): when true, after each stall booking payment capture the API calls
# POST /v1/payments/{id}/transfers to send (gross − stall_booking_commission_bps) to the organizer's linked account id
# saved under Organizer → Payout & settlement. Requires Route enabled on the merchant Razorpay account.
# RAZORPAY_ROUTE_TRANSFERS_ENABLED=false
#
# When true, saving bank+IFSC (first time, no acc_) calls Razorpay Route v2 APIs to create a linked account.
# Needs KEY_ID/SECRET, Route on merchant, valid RAZORPAY_ROUTE_LINKED_* category pair for your business, and user email+phone.
# RAZORPAY_ROUTE_AUTO_LINKED_ACCOUNT=false
# Optional stakeholder PAN if Razorpay requires it (prefer sending pan from UI stakeholderPan). Test only:
# RAZORPAY_ROUTE_STAKEHOLDER_PAN=
# Override linked-account business profile (defaults are doc placeholders — set real MCC for production):
# RAZORPAY_ROUTE_LINKED_BUSINESS_TYPE=individual
# RAZORPAY_ROUTE_LINKED_CATEGORY=healthcare
# RAZORPAY_ROUTE_LINKED_SUBCATEGORY=clinic
# RAZORPAY_ROUTE_LINKED_ADDRESS_STREET1=Registered office
# RAZORPAY_ROUTE_LINKED_ADDRESS_CITY=Mumbai
# RAZORPAY_ROUTE_LINKED_ADDRESS_STATE=MH
# RAZORPAY_ROUTE_LINKED_ADDRESS_POSTAL=400001
